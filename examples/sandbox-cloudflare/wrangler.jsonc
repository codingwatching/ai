{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-ai-sandbox-cloudflare",
  // Custom server entry: TanStack Start SSR + the agent's DOs/container in one
  // Worker. The @cloudflare/vite-plugin builds this entry and wires the client
  // assets automatically (no `assets` block needed here).
  "main": "src/server.ts",
  "compatibility_date": "2026-05-01",
  // node:crypto/node:buffer used transitively by the TanStack AI packages + the
  // MCP SDK. The DO/Worker code itself uses Web Crypto for the bearer check.
  "compatibility_flags": ["nodejs_compat"],

  // The container image that the @cloudflare/sandbox Sandbox DO runs. It ships
  // all three harness CLIs — claude, codex, grok (see Dockerfile + README
  // Limitations re: stdin) — so `HARNESS` can select one without a rebuild.
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      // A few warm instances so concurrent chat threads each get a sandbox.
      "max_instances": 5,
    },
  ],

  "durable_objects": {
    "bindings": [
      // The coordinator that owns each run (drives chat(), the run-log, the
      // WebSocket tails, and the /_bridge MCP endpoint).
      { "name": "RUN_COORDINATOR", "class_name": "RunCoordinator" },
      // The @cloudflare/sandbox container host DO.
      { "name": "Sandbox", "class_name": "Sandbox" },
    ],
  },

  "migrations": [
    {
      "tag": "v1",
      // Both DO classes use the SQLite-backed storage backend (required for the
      // sandbox SDK, and what DurableObjectRunEventLog persists run events to).
      "new_sqlite_classes": ["RunCoordinator", "Sandbox"],
    },
  ],

  // Two host surfaces, both OPTIONAL here (request-derived when unset):
  //
  // • PUBLIC_HOSTNAME — the CONTAINER→Worker bridge host (`/_bridge`, `/tool-exec`).
  //   Unset → derived from the trigger request, which is safe on Cloudflare (the
  //   edge only routes hostnames you own to your Worker). A `*.workers.dev` deploy
  //   works with ZERO config; locally the coordinator uses `host.docker.internal`.
  //   Set it only to override (e.g. a stable named dev tunnel).
  //
  // • PREVIEW_HOSTNAME — OPTIONAL, and NOT needed for this example. Browser previews
  //   default to a Cloudflare quick tunnel (`*.trycloudflare.com`) served by
  //   `cloudflared` inside the sandbox — works with zero config, local or on a
  //   `*.workers.dev` deploy. PREVIEW_HOSTNAME only applies to the alternative
  //   `exposePort`-fronted path (the Worker serves the preview on YOUR domain): that
  //   needs WILDCARD DNS, so set a `*.<domain>` route + this var, e.g.:
  //     "routes": [{ "pattern": "*.preview.example.com/*", "zone_name": "example.com" }]
  //     "vars":   { "PREVIEW_HOSTNAME": "preview.example.com" }
  //   See `resolvePreviewHost` in @tanstack/ai-sandbox-cloudflare.

  // The harness's API key is a SECRET, not a var — set the one for your chosen
  // HARNESS (see below). It is injected into the sandbox env (never persisted to
  // logs/snapshots):
  //   claude-code → wrangler secret put ANTHROPIC_API_KEY
  //   codex       → wrangler secret put CODEX_API_KEY   (or OPENAI_API_KEY)
  //   grok            → wrangler secret put XAI_API_KEY         (or GROK_API_KEY)

  "vars": {
    // Which in-sandbox coding agent to run: claude-code (default) | codex | grok.
    // The container image ships all three CLIs; this just picks which one chat()
    // drives (see selectHarness in src/agent.ts). Change it + redeploy to switch.
    "HARNESS": "claude-code",
    // Container-control transport for the Sandbox DO. `rpc` is required for
    // `sandbox.tunnels` (the quick-tunnel preview URLs `exposePreview` returns);
    // on the default `http` it throws "requires the RPC transport". The getSandbox
    // providers also pass `transport: 'rpc'` (client side) to match. See
    // `exposePreviewTool` / `cloudflareSandbox` in @tanstack/ai-sandbox-cloudflare.
    "SANDBOX_TRANSPORT": "rpc",
  },

  "observability": { "enabled": true },
}
