# OpenAI API Key (chat, images, video, speech, transcription, summarize)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API Key (chat)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini API Key (chat, audio, speech)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# xAI / Grok API Key (chat)
# Get yours at: https://console.x.ai
XAI_API_KEY=

# Groq API Key (chat)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter API Key (chat, images)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Amazon Bedrock (chat via the default Converse API)
# Create a key at: https://docs.aws.amazon.com/bedrock/latest/userguide/api-keys.html
BEDROCK_API_KEY=
# AWS_REGION=us-east-1
# To test SigV4 instead of the API key: set BEDROCK_AUTH=sigv4 and provide AWS
# IAM credentials via env vars or `aws configure` (the shared credentials file).
# BEDROCK_AUTH=sigv4

# fal.ai Key (audio, speech, transcription)
# Get yours at: https://fal.ai/dashboard/keys
FAL_KEY=

# ElevenLabs API Key (realtime voice)
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ElevenLabs Agent ID (realtime voice)
# Create an agent at: https://elevenlabs.io/app/conversational-ai
ELEVENLABS_AGENT_ID=

# ── Sandbox triage demo (/sandboxes) ────────────────────────────────────────

# GitHub token — raises API rate limits for the triage tools (issue comments,
# related-issue search) and allows private repos. Optional for public repos.
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Daytona API key — required to run triage on the Daytona provider.
# Get yours at: https://app.daytona.io
DAYTONA_API_KEY=

# Vercel Sandbox — token + stable team/project (no OIDC expiry).
# Token: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# ngrok authtoken — lets the host tool bridge reach REMOTE cloud sandboxes
# (Daytona, Vercel) while developing locally, so chat()-provided tools / code
# mode work there too. Not needed for the local or Docker providers.
# Get yours at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
